# 氛寸 · 环境变量样例 —— 复制为 .env.local 后填入真实值（.env.local 已被 git 忽略）

# 和风天气 QWeather —— 实时天气（服务端调用，key 不落前端）
QWEATHER_HOST=your-qweather-api-host
QWEATHER_KEY=your-qweather-key

# DeepSeek —— 自然语言场景解析 + 有温度的解读
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash        # 可选；不填默认即 deepseek-v4-flash（DeepSeek 最新模型）
